# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real key.

# Anthropic API key — required for API mode (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use (planner API, regression ``claude -p``, etc.):
#   claude-haiku-4-5-20251001   — fastest and cheapest; CLI alias: haiku
#   claude-sonnet-4-6           — stronger reasoning, better personalization
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Web dashboard (install.sh / make web)
# WEB_HOST=127.0.0.1
# WEB_PORT=3847
# OUTREACH_MOCK=1
# OUTREACH_DATA_ROOT=
# CLAUDE_WEB_TIMEOUT_SEC=600

# Operator notifications (sent to OPERATOR_EMAIL):
#   - schedule_meeting MCP tool → one plain-text email when a prospect agrees
#     to a call.
#   - upsert_conversation MCP tool → one plain-text email when an outreach
#     sequence transitions into a terminal stage ("ended" or "dead"),
#     deduped so the same prospect is only emailed once per sequence end.
# Leave any of OPERATOR_EMAIL or SMTP_HOST empty to disable email and just
# persist state.
# OPERATOR_EMAIL=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# Gmail + 2FA: generate an app password at https://myaccount.google.com/apppasswords
# SMTP_PASS=app-password-here
# SMTP_FROM=you@example.com
# SMTP_STARTTLS=1
# SMTP_TIMEOUT_SEC=8
# NOTIFY_DISABLED=0
