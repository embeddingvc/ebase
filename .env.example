# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real key.

# Anthropic API key — required for API mode (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use (planner API, regression ``claude -p``, etc.):
#   claude-haiku-4-5-20251001   — fastest and cheapest; CLI alias: haiku
#   claude-sonnet-4-6           — stronger reasoning, better personalization
CLAUDE_MODEL=claude-haiku-4-5-20251001
