{
  "mcpServers": {
    "linkedin": {
      "command": "/path/to/uv",
      "args": [
        "run",
        "--project",
        "/path/to/LinkedIn-Outreach",
        "/path/to/LinkedIn-Outreach/tools/server.py"
      ]
    }
  },
  "preferences": {
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "task",
    "coworkWebSearchEnabled": true
  }
}
