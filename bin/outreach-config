#!/usr/bin/env bash
# outreach-config — read/write ~/.ebase/config (key=value).
set -euo pipefail

STATE_DIR="${OUTREACH_STATE_DIR:-$HOME/.ebase}"
CONFIG_FILE="$STATE_DIR/config"

usage() {
  cat <<'EOF'
Usage: outreach-config get <key>
       outreach-config set <key> <value>

Keys:
  update_check   true|false — check for updates at skill start (default: true)
  install_local  true|false — skip syncing skills to ~/.claude/skills on upgrade
EOF
}

cfg_get() {
  local key="$1"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    case "$key" in
      update_check) echo "true" ;;
      install_local) echo "false" ;;
      *) echo "" ;;
    esac
    return 0
  fi
  local line val
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^[[:space:]]*${key}= ]]; then
      val="${line#*=}"
      val="${val#"${val%%[![:space:]]*}"}"
      val="${val%"${val##*[![:space:]]}"}"
      echo "$val"
      return 0
    fi
  done <"$CONFIG_FILE"
  case "$key" in
    update_check) echo "true" ;;
    install_local) echo "false" ;;
    *) echo "" ;;
  esac
}

cfg_set() {
  local key="$1" value="$2"
  mkdir -p "$STATE_DIR"
  local tmp replaced=0 line
  tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")"
  if [[ -f "$CONFIG_FILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" =~ ^[[:space:]]*${key}= ]]; then
        if [[ "$replaced" -eq 0 ]]; then
          printf '%s=%s\n' "$key" "$value" >>"$tmp"
          replaced=1
        fi
      else
        printf '%s\n' "$line" >>"$tmp"
      fi
    done <"$CONFIG_FILE"
  fi
  if [[ "$replaced" -eq 0 ]]; then
    printf '%s=%s\n' "$key" "$value" >>"$tmp"
  fi
  mv "$tmp" "$CONFIG_FILE"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    get)
      [[ $# -eq 2 ]] || { usage >&2; exit 1; }
      cfg_get "$2"
      ;;
    set)
      [[ $# -eq 3 ]] || { usage >&2; exit 1; }
      cfg_set "$2" "$3"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
