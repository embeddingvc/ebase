.DS_Store
.env

# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Test/tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local logs
*.log
logs/

# Local outreach identity (copy persona.json.example → persona.json)
outreach/config/persona.json

# Outreach action logs
outreach/logs/actions.jsonl

# Mock LinkedIn session store (persisted across MCP subprocesses; scenario-local only)
outreach/mock/mock_linkedin_sessions.json

# Local generated/user-specific outreach data
outreach/connections.json
outreach/generated/
outreach/mock/connections.json
outreach/mock/*/*.json
outreach/mock/storage/
outreach/logs/planned_messages.jsonl
outreach/conversations/*.json

# Claude Code local config + gstack skills (per-machine)
.claude/
CLAUDE.md

# Claude Code project-scoped MCP (paths are machine-specific; created by install.sh / make claude-install)
.mcp.json
outreach/config/dashboard_routines.json
outreach/storage/web.pid
